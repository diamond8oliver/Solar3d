PORT=3001
GOOGLE_SOLAR_API_KEY=your_key_here
NREL_API_KEY=your_key_here
# true = mock both, false = force real both, auto = real per-API where key exists
USE_MOCK_APIS=auto

# Apify (optional) — drives async enrichment of incentives, installers,
# market signals, and PVGIS irradiance per project. Leave blank to disable
# enrichment; the quote-critical path (Google Solar + PVWatts) is
# untouched either way.
APIFY_TOKEN=your_key_here
